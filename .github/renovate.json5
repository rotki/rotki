{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "dependencyDashboardAutoclose": false,
  "prCreation": "not-pending",
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchPackageNames": ["*"],
      "enabled": false
    },
    {
      "allowedVersions": "/^(24)\\./",
      "groupName": "Node.js",
      "matchPackageNames": ["@types/node", "node"]
    }
  ]
}
